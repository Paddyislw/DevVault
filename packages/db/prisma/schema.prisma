generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────

enum WorkspaceType {
  PERSONAL
  WORK
  CUSTOM
}

enum TaskPriority {
  P1
  P2
  P3
  P4
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum AttachmentType {
  CODE
  IMAGE
  LINK
  FILE
}

enum NoteType {
  NOTE
  COMMAND
}

enum CredentialCategory {
  API_KEY
  DATABASE
  SERVICE
  SSH
  OTHER
}

enum BookmarkCategory {
  DESIGN
  CODE
  TUTORIALS
  TOOLS
  APIS_DOCS
  CUSTOM
}

enum EnvEnvironment {
  DEV
  STAGING
  PROD
}

enum ApiMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

enum ApiAuthType {
  NONE
  BEARER
  API_KEY
  BASIC
}

// ─── AI & ACTIVITY ENUMS ─────────────────────────────

enum RecapType {
  WEEKLY
  MONTHLY
}

enum IdeaStatus {
  RAW
  EXPLORING
  COMMITTED
  ABANDONED
}

enum ReminderStatus {
  PENDING
  DELIVERED
  SNOOZED
  DISMISSED
}

enum ReminderCategory {
  PROFESSIONAL
  PERSONAL
  BILLING
  INFRA
  CUSTOM
}

enum ReminderRepeat {
  DAILY
  WEEKLY
  MONTHLY
}

// ─── USER ─────────────────────────────────────────────

model User {
  id                 String   @id @default(cuid())
  telegramId         String   @unique
  name               String?
  email              String?
  masterPasswordHash String?
  aiSettings         Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspaces   Workspace[]
  activityLogs ActivityLog[]
  standups     Standup[]
  recaps       Recap[]
  reminders    Reminder[]
  projectIdeas ProjectIdea[]

  @@map("users")
}

// ─── WORKSPACE ────────────────────────────────────────

model Workspace {
  id        String        @id @default(cuid())
  userId    String
  name      String
  slug      String
  color     String        @default("#4a9eed")
  icon      String?
  isDefault Boolean       @default(false)
  type      WorkspaceType @default(CUSTOM)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks        Task[]
  tags         Tag[]
  snippets     Snippet[]
  scratchpads  Scratchpad[]
  notes        Note[]
  credentials  Credential[]
  bookmarks    Bookmark[]
  envSets      EnvSet[]
  apiEndpoints ApiEndpoint[]
  reminders    Reminder[]

  @@unique([userId, slug]) //userid + slug should be personal
  @@map("workspaces")
}

// ─── TASK ─────────────────────────────────────────────

model Task {
  id           String       @id @default(cuid())
  workspaceId  String
  title        String
  description  String?
  priority     TaskPriority @default(P4)
  status       TaskStatus   @default(TODO)
  dueDate      DateTime?
  isBacklog    Boolean      @default(false)
  isSomeday    Boolean      @default(false)
  position     Int          @default(0)
  parentTaskId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentTask  Task?            @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks    Task[]           @relation("Subtasks")
  attachments TaskAttachment[]
  tags Tag[]

  @@index([workspaceId, status])
  @@index([workspaceId, dueDate])
  @@index([parentTaskId])
  @@map("tasks")
}

// ─── TASK ATTACHMENT ──────────────────────────────────

model TaskAttachment {
  id        String         @id @default(cuid())
  taskId    String
  type      AttachmentType
  content   String?
  language  String?
  url       String?
  fileName  String?
  createdAt DateTime       @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_attachments")
}

// ─── Tag ─────────────────────────────────────────
model Tag {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#4a9eed")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade) //virtual field //in this "workspace" can be any name
  task      Task[]

  @@unique([workspaceId, name]) // no duplicate tag names per workspace
  @@index([workspaceId]) // fast queries by workspace
  @@map("tags") // table name in PostgreSQL
}

// If you named it "workspace":
// const tag = await prisma.tag.findFirst({ include: { workspace: true } });
// tag.workspace.name   // "Personal" //it returns the join query result with the correct name, but the field name "workspace" is misleading because it contains the tag's workspace data, not the tag itself.

// If you named it "banana":
//const tag = await prisma.tag.findFirst({ include: { banana: true } });
//tag.banana.name   // "Personal" — same data, confusing name // it also returns the join query result, but the field name "banana" is even more misleading because it has nothing to do with the tag or workspace, making it harder to understand the code at a glance.

//The type (Workspace) is what matters. That tells Prisma which table to look up. The name is just your label for it.

// ─── SNIPPET ──────────────────────────────────────────

model Snippet {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  code        String
  language    String   @default("plaintext")
  tags        String[] @default([])
  usageCount  Int      @default(0)
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([language])
  @@map("snippets")
}

// ─── SCRATCHPAD ───────────────────────────────────────

model Scratchpad {
  id          String    @id @default(cuid())
  workspaceId String
  content     String
  language    String    @default("plaintext")
  expiresAt   DateTime?
  isPromoted  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([expiresAt])
  @@map("scratchpads")
}

// ─── NOTE ─────────────────────────────────────────────

model Note {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  content     String
  type        NoteType @default(NOTE)
  command     String?
  language    String?
  warning     String?
  source      String?
  tags        String[] @default([])
  isPinned    Boolean  @default(false)
  copyCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([type])
  @@map("notes")
}

// ─── CREDENTIAL ───────────────────────────────────────

model Credential {
  id            String             @id @default(cuid())
  workspaceId   String
  name          String
  service       String
  encryptedData String
  iv            String
  category      CredentialCategory @default(OTHER)
  lastCopiedAt  DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([service])
  @@map("credentials")
}

// ─── BOOKMARK ─────────────────────────────────────────

model Bookmark {
  id            String           @id @default(cuid())
  workspaceId   String
  url           String
  title         String?
  description   String?
  favicon       String?
  category      BookmarkCategory @default(CUSTOM)
  tags          String[]         @default([])
  isAlive       Boolean          @default(true)
  lastCheckedAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([category])
  @@map("bookmarks")
}

// ─── ENV SET ──────────────────────────────────────────

model EnvSet {
  id          String         @id @default(cuid())
  workspaceId String
  projectName String
  environment EnvEnvironment @default(DEV)
  variables   String // Encrypted JSON
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, projectName, environment])
  @@index([workspaceId])
  @@map("env_sets")
}

// ─── API ENDPOINT ─────────────────────────────────────

model ApiEndpoint {
  id             String      @id @default(cuid())
  workspaceId    String
  name           String
  url            String
  method         ApiMethod   @default(GET)
  headers        Json        @default("{}")
  body           Json        @default("{}")
  authType       ApiAuthType @default(NONE)
  projectName    String?
  lastPingStatus Int?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("api_endpoints")
}

// ─── ACTIVITY LOG ─────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([entityType])
  @@map("activity_logs")
}

// ─── STANDUP ──────────────────────────────────────────

model Standup {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime @db.Date
  content      String
  deliveredVia String   @default("telegram")
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("standups")
}

// ─── RECAP ────────────────────────────────────────────

model Recap {
  id          String    @id @default(cuid())
  userId      String
  periodStart DateTime
  periodEnd   DateTime
  type        RecapType @default(WEEKLY)
  content     String
  stats       Json      @default("{}")
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("recaps")
}

// ─── REMINDER ─────────────────────────────────────────

model Reminder {
  id               String           @id @default(cuid())
  userId           String
  workspaceId      String?
  title            String
  description      String?
  remindAt         DateTime
  repeatRule       ReminderRepeat?
  repeatEndDate    DateTime?
  category         ReminderCategory @default(PROFESSIONAL)
  priority         TaskPriority?
  linkedEntityType String?
  linkedEntityId   String?
  status           ReminderStatus   @default(PENDING)
  snoozedUntil     DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([remindAt])
  @@map("reminders")
}

// ─── PROJECT IDEA ─────────────────────────────────────

model ProjectIdea {
  id                    String     @id @default(cuid())
  userId                String
  title                 String
  description           String?
  techStack             String[]   @default([])
  status                IdeaStatus @default(RAW)
  references            String[]   @default([])
  promotedToWorkspaceId String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("project_ideas")
}
